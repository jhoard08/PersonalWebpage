doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    link(rel='stylesheet', href='css/bootstrap.min.css')
    link(rel='stylesheet', href='css/fonts.css')
    link(rel='stylesheet', href='css/site.css')
    title Jake Hoard
  body
    include head.pug

    //- Hero Section
    section.hero
      .hero-overlay
      .container.hero-content
        h1.hero-title Jake Hoard
        p.hero-subtitle Software Engineer
        a.hero-scroll(href='#about')
          svg(xmlns='http://www.w3.org/2000/svg', width='32', height='32', viewBox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
            polyline(points='6 9 12 15 18 9')

    //- About Section
    section#about.about
      .container
        .row.align-items-center
          .col-lg-4.text-center.mb-4.mb-lg-0
            img.about-photo(src='/images/STP_0337.JPG', alt='Jake Hoard')
          .col-lg-8
            h2.section-heading About Me
            p.about-text
              | I'm a software engineer with experience across the full stack &mdash; from
              | embedded systems and desktop applications to modern web development.
              | I enjoy building clean, reliable software and am always looking for
              | new challenges to sharpen my skills.

    //- Software Section
    section.software
      .container
        h2.section-heading.text-white Software
        .row
          .col-md-6
            .project-card
              .project-card-body
                h3.project-card-title Java
                p.project-card-desc Desktop and command-line applications built with Java.
                a.project-link(href='/projects') View Projects &rarr;
          .col-md-6
            .project-card
              .project-card-body
                h3.project-card-title Embedded
                p.project-card-desc Low-level firmware and hardware-interfacing projects.
                a.project-link(href='/projects') View Projects &rarr;
          .col-md-6
            .project-card
              .project-card-body
                h3.project-card-title C#
                p.project-card-desc Applications and tools built with .NET and C#.
                a.project-link(href='/projects') View Projects &rarr;
          .col-md-6
            .project-card
              .project-card-body
                h3.project-card-title Web
                p.project-card-desc Full-stack web applications using Node.js, Express, and modern frameworks.
                a.project-link(href='/projects') View Projects &rarr;

    //- Footer
    footer.site-footer
      .container.text-center
        p &copy; #{new Date().getFullYear()} Jake Hoard

    script(src='/includes/jquery.min.js')
    script(src='/includes/popper.min.js')
    script(src='/includes/bootstrap.min.js')
    script(src='/scripts/nav.js')
